{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "case-slide-gen/body-blueprint",
  "title": "Case Slide Gen Body Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slide_number",
    "key_message",
    "layout_family",
    "layout_variant",
    "dominance_structure",
    "hero_block",
    "support_blocks",
    "reading_order",
    "device_placement",
    "must_remain_prominent",
    "copy_slots",
    "reference_links"
  ],
  "properties": {
    "slide_number": {
      "type": "integer",
      "minimum": 1
    },
    "key_message": {
      "type": "string"
    },
    "layout_family": {
      "type": "string"
    },
    "layout_variant": {
      "type": "string"
    },
    "dominance_structure": {
      "type": "string",
      "enum": [
        "hero",
        "split",
        "distributed"
      ]
    },
    "hero_block": {
      "type": "string"
    },
    "support_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "reading_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "device_placement": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "device_id",
          "placement_role",
          "target_block"
        ],
        "properties": {
          "device_id": {
            "type": "string"
          },
          "placement_role": {
            "type": "string",
            "enum": [
              "hero",
              "support",
              "proof",
              "bridge"
            ]
          },
          "target_block": {
            "type": "string"
          }
        }
      }
    },
    "must_remain_prominent": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "copy_slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slot_id",
          "slot_type",
          "target_block"
        ],
        "properties": {
          "slot_id": {
            "type": "string"
          },
          "slot_type": {
            "type": "string",
            "enum": [
              "hero-number",
              "hero-label",
              "support-metric",
              "support-title",
              "callout",
              "caption",
              "table-cell",
              "axis-label",
              "summary-takeaway"
            ]
          },
          "target_block": {
            "type": "string"
          }
        }
      }
    },
    "reference_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
