{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "case-slide-gen/layout-grammar-entry",
  "title": "Case Slide Gen Layout Grammar Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grammar_id",
    "fits_classes",
    "not_for",
    "dominance_structure",
    "required_blocks",
    "allowed_visual_devices",
    "reading_order",
    "usage_notes"
  ],
  "properties": {
    "grammar_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "fits_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "not_for": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "common_decision_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "common_data_shapes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "dominance_structure": {
      "type": "string",
      "enum": [
        "hero",
        "split",
        "distributed"
      ]
    },
    "required_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "optional_blocks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_visual_devices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "reading_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "usage_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "avoid_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
