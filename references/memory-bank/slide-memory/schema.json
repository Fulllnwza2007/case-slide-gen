{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "case-slide-gen/slide-memory-entry",
  "title": "Case Slide Gen Slide Memory Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slide_id",
    "source_deck",
    "source_file",
    "page",
    "image_path",
    "content_classes",
    "decision_types",
    "data_shapes",
    "visual_devices",
    "layout_family",
    "dominance_structure",
    "body_goal",
    "body_structure",
    "when_to_use",
    "avoid_when",
    "why_it_works",
    "adaptation_notes"
  ],
  "properties": {
    "slide_id": {
      "type": "string",
      "description": "Stable unique ID for the reference slide."
    },
    "source_deck": {
      "type": "string",
      "description": "Human-readable deck name or slug."
    },
    "source_file": {
      "type": "string",
      "description": "Original PDF filename."
    },
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "image_path": {
      "type": "string",
      "description": "Absolute or vault-relative path to the slide image."
    },
    "section_type": {
      "type": "string"
    },
    "primary_message": {
      "type": "string"
    },
    "content_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "decision_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "data_shapes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "visual_devices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "layout_family": {
      "type": "string"
    },
    "dominance_structure": {
      "type": "string",
      "enum": [
        "hero",
        "split",
        "distributed"
      ]
    },
    "density_hint": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "body_goal": {
      "type": "string"
    },
    "body_structure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hero_block",
        "support_blocks",
        "reading_order"
      ],
      "properties": {
        "hero_block": {
          "type": "string"
        },
        "support_blocks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reading_order": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "chart_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "table_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "when_to_use": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "avoid_when": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "why_it_works": {
      "type": "string"
    },
    "adaptation_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
